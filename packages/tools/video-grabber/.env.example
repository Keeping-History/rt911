# PostgreSQL connection for the video_grabber pipeline database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/video_grabber

# Wasabi S3 credentials (us-central-1 region)
WASABI_ENDPOINT_URL=https://s3.us-central-1.wasabisys.com
WASABI_BUCKET=files.911realtime.org
WASABI_ACCESS_KEY_ID=
WASABI_SECRET_ACCESS_KEY=

# Directus API — use a static token (never session tokens; they race across concurrent workers)
DIRECTUS_URL=http://localhost:8055
DIRECTUS_API_TOKEN=
# Legacy email/password auth (unused by worker; kept for manual admin tasks only)
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Internet Archive rate limiting (max 2 concurrent downloads per IA bulk guidelines)
IA_RATE_PER_SEC=2

# Minimum broadcast duration to consider a candidate (12 min = 720s)
MIN_DURATION_SECONDS=720

# Prefect server (in-cluster format)
PREFECT_API_URL=http://prefect-server.video-grabber.svc.cluster.local:4200/api
