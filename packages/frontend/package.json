{
	"name": "@rt911/frontend",
	"private": true,
	"version": "1.0.0",
	"type": "module",
	"scripts": {
		"dev": "vite -d",
		"build": "tsc -b && vite build",
		"test": "vitest run",
		"lint": "eslint .",
		"preview": "vite preview",
		"use:local": "npm link classicy",
		"use:published": "npm unlink classicy && npm install",
		"proxy": "npm run proxy:up",
		"proxy:cycle": "npm run proxy:down && npm run proxy:up",
		"proxy:up": "cd timemachine && docker compose up --build --force-recreate -d",
		"proxy:down": "cd timemachine && docker compose down",
		"e2e":        "playwright test",
		"e2e:ui":     "playwright test --ui",
		"e2e:headed": "playwright test --headed",
		"codegen":    "playwright codegen"
	},
	"dependencies": {
		"@msgpack/msgpack": "^3.1.3",
		"@openreplay/tracker": "^18.0.17",
		"classicy": "latest",
		"classnames": "^2.5.1",
		"dompurify": "^3.4.11",
		"html2canvas-pro": "^2.2.1",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"react-player": "^3.4.0",
		"sass-embedded": "^1.100.0"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@playwright/test": "^1.61.1",
		"@testing-library/react": "^16.3.2",
		"@types/dompurify": "^3.0.5",
		"@types/node": "^25.9.3",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.2",
		"eslint": "^10.4.1",
		"eslint-plugin-react-hooks": "^7.0.1",
		"eslint-plugin-react-refresh": "^0.5.0",
		"globals": "^17.6.0",
		"jsdom": "^29.1.1",
		"typescript": "~6.0.3",
		"typescript-eslint": "^8.61.0",
		"vite": "^8.0.16",
		"vitest": "^4.1.8"
	},
	"volta": {
		"node": "25.2.0"
	}
}
