# TimeMachine Web Proxy — local dev configuration
# Copy this file to .env and adjust as needed.
#
# The example app (Vite) runs on http://localhost:5173 by default.
# The Browser app connects to the proxy at http://localhost:8765.
# Set VITE_PROXY_PROTOCOL=https: when the proxy is served over TLS (e.g. Cloud Run).

# Port the proxy listens on inside the container (also mapped to the host).
TIMEMACHINE_PORT=8765

# Bind address inside the container. Must be 0.0.0.0 to be reachable from the host.
LISTENER=0.0.0.0

# Wayback Machine archive timestamp to retrieve (YYYYMMDDHHmmss).
# 20010911000000 = September 11, 2001 — classic web era default.
ARCHIVE_TIME=20010911000000

# Base URL of the archive source. Change this to point at a different archive.
URL_PREFIX=https://web.archive.org/web

# Allowed CORS origin. Must match the address you open the example app from.
CORS_ORIGIN=http://localhost:5173

# Local directory used for caching fetched pages (inside the container).
CACHE_DIR=/app/cache

# Set HOST_CACHE_DIR to a host path to persist the cache across container restarts.
# Leave unset to use an anonymous Docker volume.
# HOST_CACHE_DIR=./cache

# Rate limiting for Wayback Machine requests.
ARCHIVE_RATE_PER_SEC=10
ARCHIVE_BURST=3
ARCHIVE_MAX_RETRIES=5
BACKOFF_INTERVAL_SEC=10

# Set to false to disable the on-disk response cache.
CACHE_ENABLED=true

# Public base URL of this proxy (used for self-referencing links in responses).
PROXY_BASE_URL=http://localhost:8765

# Token required to call the cache-clear endpoint. Change this to something secret.
CACHE_CLEAR_TOKEN=dev-token

# ---------------------------------------------------------------------------
# Frontend (Vite client) configuration
# ---------------------------------------------------------------------------
# Only variables prefixed with VITE_ are exposed to browser code via
# import.meta.env. They are read at build time, so set them before `vite build`
# (or `vite dev`). Each one below has a built-in fallback in the source, so all
# are optional — uncomment to override.

# Where the Browser app sends archive requests. These are split into protocol,
# host, and port so the app can reassemble the proxy origin.
# NOTE: VITE_PROXY_PROTOCOL must include the trailing colon (e.g. "http:" or
# "https:"). Use https: when the proxy is served over TLS (e.g. Cloud Run).
# Defaults: http: / localhost / 8765
# VITE_PROXY_PROTOCOL=http:
# VITE_PROXY_HOST=localhost
# VITE_PROXY_PORT=8765

# WebSocket endpoint for the live media stream provider (MediaStreamProvider).
# Use ws:// for plain HTTP and wss:// behind TLS.
# Default: ws://localhost:8080/stream
VITE_MEDIA_STREAM_URL=wss://stream-beta.911realtime.org/stream

# HTTP base URL of the streamer service, used by the Feedback app to POST /feedback.
# Default: http://localhost:8080
VITE_FEEDBACK_URL=http://localhost:8080

# OpenReplay session recording. Leave unset to disable the tracker locally.
# After deploying the OpenReplay server, copy the project key from the dashboard.
# VITE_OPENREPLAY_PROJECT_KEY=your-project-key-here
# VITE_OPENREPLAY_INGEST_URL=https://openreplay.911realtime.org/ingest
