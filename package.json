{
	"name": "classicy-example",
	"private": true,
	"version": "1.0.0",
	"type": "module",
	"scripts": {
		"dev": "vite -d",
		"build": "tsc -b && vite build",
		"lint": "eslint .",
		"preview": "vite preview",
		"use:local": "npm link classicy",
		"use:published": "npm unlink classicy && npm install",
		"proxy": "npm run proxy:up",
		"proxy:cycle": "npm run proxy:down && npm run proxy:up",
		"proxy:up": "cd timemachine && docker compose up --build --force-recreate -d",
		"proxy:down": "cd timemachine && docker compose down"
	},
	"dependencies": {
		"classicy": "*",
		"dompurify": "^3.4.0",
		"react": "^19.1.0",
		"react-dom": "^19.1.0"
	},
	"devDependencies": {
		"@eslint/js": "^9.39.1",
		"@types/dompurify": "^3.0.5",
		"@types/node": "^24.1.0",
		"@types/react": "^19.2.5",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^5.1.1",
		"eslint": "^9.39.1",
		"eslint-plugin-react-hooks": "^7.0.1",
		"eslint-plugin-react-refresh": "^0.5.0",
		"globals": "^17.3.0",
		"typescript": "~5.9.3",
		"typescript-eslint": "^8.46.4",
		"vite": "^7.3.2"
	},
	"volta": {
		"node": "25.2.0"
	}
}
